# Bayan local development environment template
# Copy this file to .env and set values for your machine.
# Note: The current app reads environment variables from the shell/process.
# If you use .env directly, load it in your shell or integrate dotenv in startup scripts.

# Backend server
PORT=8787
BAYAN_DB_PATH=backend/data/bayan.sqlite
AUTH_SESSION_TTL_DAYS=30

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3

# Optional STT (whisper.cpp)
WHISPER_CPP_BIN=
WHISPER_MODEL_PATH=
FFMPEG_BIN=

# Optional TTS (piper)
PIPER_BIN=
PIPER_MODEL_PATH=

# Desktop -> backend bridge
BAYAN_BACKEND_URL=http://127.0.0.1:8787
